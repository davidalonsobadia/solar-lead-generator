# Sunscout Frontend Environment Variables

NEXT_PUBLIC_API_KEY=your-api-key-here
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Maps key for the browser (the ONLY Google key allowed client-side).
# Must be domain/referrer-restricted in the Google console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
